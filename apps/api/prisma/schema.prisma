generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CrmUser {
  id           String   @id @default(cuid())
  email        String   @unique
  fullName     String
  passwordHash String
  role         String   @default("admin")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BotGlobalSetting {
  id              String   @id @default(cuid())
  botEnabled      Boolean  @default(true) @map("bot_enabled")
  maintenanceMode Boolean  @default(false) @map("maintenance_mode")
  maintenanceMessage String? @map("maintenance_message")
  updatedBy       String?  @map("updated_by")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("bot_global_settings")
}

model ChatControl {
  phone         String   @id
  botEnabled    Boolean  @default(true) @map("bot_enabled")
  humanTakeover Boolean  @default(false) @map("human_takeover")
  assignedTo    String?  @map("assigned_to")
  status        String   @default("active")
  notes         String?
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("chat_controls")
}

model BotBlacklist {
  id        String   @id @default(cuid())
  phone     String   @unique
  reason    String?
  active    Boolean  @default(true)
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("bot_blacklist")
}

model ChatNote {
  id        String   @id @default(cuid())
  phone     String
  note      String
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("chat_notes")
}

model Incident {
  id          String   @id @default(cuid())
  phone       String
  status      String   @default("open")
  severity    String   @default("low")
  branch      String?
  summary     String?
  assignedTo  String?
  resolvedAt  DateTime?
  lastAlertAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model IncidentState {
  id            String   @id @default(cuid())
  phone         String
  status        String   @default("open")
  severity      String   @default("low")
  branch        String?
  summary       String?
  sourceAlertId Int?     @map("source_alert_id")
  lastAlertAt   DateTime? @map("last_alert_at")
  lastMessageAt DateTime? @map("last_message_at")
  assignedTo    String?  @map("assigned_to")
  resolvedAt    DateTime? @map("resolved_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([phone, status])
  @@map("incident_state")
}

model IncidentEvent {
  id         String   @id @default(cuid())
  incidentId String   @map("incident_id")
  eventType  String   @map("event_type")
  payload    Json?
  createdBy  String?  @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([incidentId, createdAt])
  @@map("incident_events")
}

model OrderDraft {
  id              String   @id @default(cuid())
  phone           String
  customerName    String?  @map("customer_name")
  branch          String?
  serviceType     String?  @map("service_type")
  itemsSummary    String?  @map("items_summary")
  deliveryAddress String?  @map("delivery_address")
  paymentMethod   String?  @map("payment_method")
  observations    String?
  status          String   @default("pending_validation")
  sourceMessageId String?  @map("source_message_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([phone, updatedAt])
  @@map("order_drafts")
}

model ReservationDraft {
  id              String   @id @default(cuid())
  phone           String
  customerName    String?  @map("customer_name")
  branch          String?
  peopleCount     Int?     @map("people_count")
  reservationDate String?  @map("reservation_date")
  reservationTime String?  @map("reservation_time")
  observations    String?
  status          String   @default("pending_validation")
  sourceMessageId String?  @map("source_message_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([phone, updatedAt])
  @@map("reservation_drafts")
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  action     String
  actor      String?
  payload    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, createdAt])
  @@map("audit_logs")
}
